{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "gtk-layer-shell-test",
  "version": "0.1.0",
  "identifier": "com.nitka.gtk-layer-shell-test",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "visible": false,
        "resizable": false,
        "decorations": false,
        "width": 1920,
        "height": 100,
        "x": 0,
        "y": 0,
        "devtools": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
